---
import {
  faBluesky,
  faGithub,
  faLinkedin,
  faXTwitter,
} from "@fortawesome/free-brands-svg-icons";
import { faEnvelope } from "@fortawesome/free-solid-svg-icons";
import FontAwesomeIcon from "../components/FontAwesomeIcon.astro";

const socials = [
  {
    icon: faBluesky,
    href: "https://bsky.app/profile/rtbenfield.dev",
    label: "Bluesky",
  },
  {
    icon: faXTwitter,
    href: "https://twitter.com/rtbenfield",
    label: "X (Twitter)",
  },
  { icon: faGithub, href: "https://github.com/rtbenfield", label: "GitHub" },
  {
    icon: faLinkedin,
    href: "https://www.linkedin.com/in/tylerbenfield/",
    label: "LinkedIn",
  },
  { icon: faEnvelope, href: "mailto:tyler@tylerbenfield.me", label: "Email" },
];
---

<footer
  class="mx-auto mt-12 flex w-full max-w-5xl flex-col items-center justify-between gap-6 border-t border-tokyo-fg-dim/10 px-4 py-10 text-sm text-tokyo-fg-muted sm:flex-row sm:px-6 lg:px-8"
>
  <span class="font-medium">© Tyler Benfield {new Date().getFullYear()}</span>
  <ul class="flex gap-2">
    {
      socials.map(({ icon, href, label }) => (
        <li>
          <a
            href={href}
            target="_blank"
            title={`Find me on ${label}`}
            class="flex h-10 w-10 items-center justify-center rounded-full text-lg text-tokyo-fg-muted no-underline transition-all hover:bg-tokyo-fg/5 hover:text-tokyo-cyan hover:shadow-[0_0_20px_-5px_var(--tokyo-cyan)]"
          >
            <FontAwesomeIcon icon={icon} />
          </a>
        </li>
      ))
    }
  </ul>
</footer>

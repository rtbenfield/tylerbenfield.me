---
import { faSpotify, faYoutube } from "@fortawesome/free-brands-svg-icons";
import { faComment, faPlay, faPodcast } from "@fortawesome/free-solid-svg-icons";
import { render } from "astro:content";
import type { CollectionEntry } from "astro:content";
import FontAwesomeIcon from "../components/FontAwesomeIcon.astro";
import {
  formatEventDate,
  formatEventMonthYear,
} from "../lib/format-event-date";

interface Props {
  event: CollectionEntry<"events">;
  expanded: boolean;
}

const { event, expanded } = Astro.props;
const { Content } = await render(event);
const monthYear = formatEventMonthYear(event.data);
const fullDate = formatEventDate(event.data);
const today = new Date().toISOString().slice(0, 10);
const isEvent = "event" in event.data;
const series = "event" in event.data ? event.data.event : event.data.podcast;
const isUpcoming = isEvent && event.data.startDate >= today;
const spotify = "podcast" in event.data ? event.data.podcast.spotify : undefined;
const pocketCasts = "podcast" in event.data ? event.data.podcast.pocketCasts : undefined;
const youtubeUrl = event.data.youtubeId
  ? `https://www.youtube.com/watch?v=${event.data.youtubeId}`
  : undefined;
const actionLink = event.data.link;
---

<article
  class:list={[
    "group relative pl-6 sm:pl-8",
    "before:absolute before:left-2 before:top-2 before:h-2 before:w-2 before:rounded-full before:bg-tokyo-cyan sm:before:left-3",
    "after:absolute after:left-[0.75rem] after:top-4 after:h-[calc(100%+1rem)] after:w-px after:bg-tokyo-cyan/30 sm:after:left-[1rem]",
    "last:after:hidden",
  ]}
>
  <div
    class="flex flex-col gap-2 sm:flex-row sm:flex-wrap sm:items-baseline sm:gap-x-4 sm:gap-y-1"
  >
    <time
      datetime={event.data.startDate}
      class="font-mono text-xs font-semibold uppercase tracking-wider text-tokyo-fg-muted sm:text-sm"
    >
      {monthYear}
    </time>
    <span
      class:list={[
        "inline-flex w-fit items-center gap-1.5 rounded-full px-2.5 py-0.5 text-xs font-semibold capitalize",
        isEvent
          ? "bg-tokyo-cyan/10 text-tokyo-cyan"
          : "bg-tokyo-purple/10 text-tokyo-purple",
      ]}
    >
      {isEvent ? "Talk" : "Podcast"}
    </span>
    <a
      href={series.href}
      target="_blank"
      class="text-sm font-medium text-tokyo-fg-muted no-underline transition-colors hover:text-tokyo-blue"
    >
      {series.name}
    </a>
    {
      isUpcoming && (
        <span class="inline-flex w-fit items-center gap-1.5 rounded-full bg-tokyo-cyan/10 px-2.5 py-0.5 text-xs font-semibold text-tokyo-cyan">
          <FontAwesomeIcon icon={faComment} class="text-[0.7em]" />
          Upcoming
        </span>
      )
    }
  </div>

  {
    (actionLink || youtubeUrl || spotify || pocketCasts) && (
      <div class="mt-2 flex flex-wrap items-center gap-3">
        {actionLink && (
          <a
            href={actionLink.href}
            target="_blank"
            class="inline-flex items-center gap-1.5 text-sm font-medium text-tokyo-blue no-underline transition-colors hover:text-tokyo-cyan"
          >
            <FontAwesomeIcon icon={faPlay} class="text-[0.9em]" />
            {actionLink.text}
          </a>
        )}
        {youtubeUrl && (
          <a
            href={youtubeUrl}
            target="_blank"
            class="inline-flex items-center gap-1.5 text-sm font-medium text-tokyo-red no-underline transition-colors hover:text-tokyo-cyan"
          >
            <FontAwesomeIcon icon={faYoutube} class="text-[0.9em]" />
            YouTube
          </a>
        )}
        {spotify && (
          <a
            href={spotify}
            target="_blank"
            class="inline-flex items-center gap-1.5 text-sm font-medium text-tokyo-green no-underline transition-colors hover:text-tokyo-cyan"
          >
            <FontAwesomeIcon icon={faSpotify} class="text-[0.9em]" />
            Spotify
          </a>
        )}
        {pocketCasts && (
          <a
            href={pocketCasts}
            target="_blank"
            class="inline-flex items-center gap-1.5 text-sm font-medium text-tokyo-orange no-underline transition-colors hover:text-tokyo-cyan"
          >
            <FontAwesomeIcon icon={faPodcast} class="text-[0.9em]" />
            Pocket Casts
          </a>
        )}
      </div>
    )
  }

  <h3 class="mt-2 text-lg font-bold leading-snug sm:text-xl">
    <a
      href={`/events/${event.id}`}
      class="text-tokyo-fg no-underline transition-colors group-hover:text-tokyo-cyan"
    >
      {event.data.title}
    </a>
  </h3>

  {
    expanded && (
      <div class="mt-3 space-y-3 text-tokyo-fg-muted">
        <p class="text-sm text-tokyo-fg-muted">{fullDate}</p>
        <div class="space-y-3 leading-relaxed">
          <Content />
        </div>
      </div>
    )
  }
</article>

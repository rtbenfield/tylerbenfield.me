---
import "@fontsource/inter";
import "../styles/global.css";
import Announcement from "../components/Announcement.astro";
import Footer from "../components/Footer.astro";
import Navbar from "../components/Navbar.astro";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Tyler Benfield" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="flex min-h-screen flex-col">
    <Announcement />
    <Navbar />

    <main class="mx-auto w-full max-w-4xl flex-1 px-4 py-6 sm:px-6 lg:px-8">
      <div class="rounded-3xl bg-tokyo-bg-soft p-6 shadow-lg sm:p-8">
        <slot />
      </div>
    </main>

    <Footer />
  </body>
</html>

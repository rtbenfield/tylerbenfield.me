---
import {
  faBluesky,
  faGithub,
  faLinkedin,
  faXTwitter,
} from "@fortawesome/free-brands-svg-icons";
import {
  faEnvelope,
  faGlobe,
  faMicrophone,
} from "@fortawesome/free-solid-svg-icons";
import FontAwesomeIcon from "../components/FontAwesomeIcon.astro";
import Layout from "../layouts/Layout.astro";

const links = [
  {
    icon: faGlobe,
    href: "https://tylerbenfield.me",
    label: "Website",
    description: "My personal site",
  },
  {
    icon: faMicrophone,
    href: "/events",
    label: "Talks & Podcasts",
    description: "Conference talks and podcast appearances",
  },
  {
    icon: faBluesky,
    href: "https://bsky.app/profile/rtbenfield.dev",
    label: "Bluesky",
    description: "@rtbenfield.dev",
  },
  {
    icon: faXTwitter,
    href: "https://twitter.com/rtbenfield",
    label: "X (Twitter)",
    description: "@rtbenfield",
  },
  {
    icon: faGithub,
    href: "https://github.com/rtbenfield",
    label: "GitHub",
    description: "@rtbenfield",
  },
  {
    icon: faLinkedin,
    href: "https://www.linkedin.com/in/tylerbenfield/",
    label: "LinkedIn",
    description: "Tyler Benfield",
  },
  {
    icon: faEnvelope,
    href: "mailto:tyler@tylerbenfield.me",
    label: "Email",
    description: "tyler@tylerbenfield.me",
  },
];
---

<Layout title="Links | Tyler Benfield">
  <div class="mx-auto flex max-w-md flex-col items-center">
    <div class="mb-8 flex flex-col items-center text-center">
      <div class="relative mb-4 h-24 w-24">
        <div
          class="absolute -inset-1 bg-linear-to-br from-tokyo-cyan/40 via-tokyo-blue/25 to-tokyo-purple/40 rounded-full"
        >
        </div>
        <div class="relative overflow-hidden rounded-full">
          <img
            class="h-full w-full object-cover"
            src="/me.webp"
            alt="Tyler Benfield"
          />
        </div>
      </div>
      <h1 class="text-2xl font-extrabold tracking-tight">
        <span class="gradient-text">Tyler Benfield</span>
      </h1>
      <p class="mt-2 text-sm text-tokyo-fg-muted">
        Software Engineer &mdash; Making databases more approachable
      </p>
    </div>

    <div class="flex w-full flex-col gap-3">
      {
        links.map(({ icon, href, label, description }) => (
          <a
            href={href}
            target={href.startsWith("/") ? undefined : "_blank"}
            rel={href.startsWith("/") ? undefined : "noopener noreferrer"}
            class="glass gradient-border group flex items-center gap-4 rounded-2xl px-5 py-4 no-underline transition-all hover:-translate-y-0.5 hover:shadow-[0_0_30px_-8px_var(--tokyo-cyan)]"
          >
            <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-tokyo-bg-highlight/50 text-lg text-tokyo-cyan transition-colors group-hover:bg-tokyo-cyan/20">
              <FontAwesomeIcon icon={icon} />
            </span>
            <div class="min-w-0 flex-1">
              <span class="block font-semibold text-tokyo-fg transition-colors group-hover:text-tokyo-cyan">
                {label}
              </span>
              <span class="block truncate text-sm text-tokyo-fg-dim">
                {description}
              </span>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</Layout>
